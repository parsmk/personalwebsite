---
import RootLayout from "../layouts/RootLayout.astro";
import Navbar from "../components/Navbar.astro";
---

<RootLayout pageTitle="PMK Development">
  <div class="flex items-center justify-center h-screen">
    <div class="flex flex-row gap-2">
      <img src="" alt="bg-placeholder" class="absolute inset-0 -z-1" />
      <div
        class="flex flex-col justify-center items-end rounded-tl-full rounded-bl-full bg-secondary/50 size-100 border-r-2 border-r-foreground"
      >
        <div class="w-[80%]">
          <h1 class="font-bold text-5xl text-foreground">PMK Development</h1>
          <h2 class="text-2xl text-foreground/70 my-2">
            Software Engineer, Full-Stack Developer
          </h2>
        </div>
      </div>
      <img class="h-[80%] outline-1" src="" alt="placeholder" />
    </div>
  </div>
  <Navbar />
</RootLayout>
