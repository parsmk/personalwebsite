---
import HeroCodeCard from "./HeroCodeCard.astro";
---

<div class="flex flex-row items-center justify-center grow gap-2">
  <img
    src="public/hero-bg.jpg"
    alt="bg-placeholder"
    class="absolute inset-0 -z-1"
  />
  <div class="flex flex-col justify-center items-end rounded-tl-full size-100">
    <div class="w-[80%]">
      <h1 class="font-bold text-5xl text-accent">PMK Development</h1>
      <h2 class="text-2xl text-accent/70 my-2">
        Software Engineer, Full-Stack Developer
      </h2>
    </div>
  </div>
  <img src="public/hero-img.png" class="h-[75%]" />
</div>
