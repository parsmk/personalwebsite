---
interface Props {
  classes: string;
}

const { classes } = Astro.props;
---

<svg
  width="800px"
  height="800px"
  viewBox="0 0 24 24"
  xmlns="http://www.w3.org/2000/svg"
  class=`${classes} stroke-accent transition fill-white  hover:-translate-y-1 duration-300`
>
  <rect
    x="3"
    y="5"
    width="18"
    height="14"
    rx="2"
    stroke-width="2"
    stroke-linecap="round"></rect>
  <path
    d="M4 7.00005L10.2 11.65C11.2667 12.45 12.7333 12.45 13.8 11.65L20 7"
    fill="none"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"></path>
</svg>
